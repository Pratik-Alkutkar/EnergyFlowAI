# EnergyFlow AI – Backend Environment Variables

APP_ENV=production
CORS_ORIGINS=https://your-app.vercel.app

# EIA API key (free at eia.gov/opendata)
# Enables real ERCOT hourly demand + price data
# Without this, demand is derived from real Open-Meteo weather data
EIA_API_KEY=your_eia_key_here

# Optional – enables GPT-4o-mini in the AI copilot
OPENAI_API_KEY=

# Battery config (optional overrides)
BATTERY_CAPACITY_KWH=100
BATTERY_MAX_CHARGE_KW=50
BATTERY_MAX_DISCHARGE_KW=50
BATTERY_EFFICIENCY=0.92
